FROM node:24-slim

WORKDIR /app

# Install runtime dependencies. node:24 ships node:sqlite as stable, so no
# native build toolchain is needed. --ignore-scripts skips the postinstall
# that tries to wire panopticon into Claude Code (irrelevant in this image).
COPY package.json pnpm-lock.yaml ./
RUN npm install -g pnpm && \
    pnpm install --prod --frozen-lockfile --ignore-scripts

# Copy built artifacts produced by `pnpm build` on the host
COPY dist/ dist/
COPY bin/ bin/

# Put `panopticon` on PATH
RUN ln -s /app/bin/panopticon /usr/local/bin/panopticon

EXPOSE 4318

CMD ["node", "dist/server.js"]
